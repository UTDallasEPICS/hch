generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String           @id
  name            String
  email           String
  emailVerified   Boolean          @default(false)
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sessions        Session[]
  accounts        Account[]
  formAssignments FormAssignment[]
  aceResponses    AceResponse[]

  @@unique([email])
  @@map("user")
}

// Form metadata (e.g. ACE Questionnaire)
model Form {
  id              String           @id @default(cuid())
  title           String
  description     String?
  slug            String           @unique // e.g. 'ace-form'
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  formQuestions   FormQuestion[]
  assignments     FormAssignment[]
  sourceDocuments DocumentUpload[] // forms created via the converter

  @@map("form")
}

// Master list of all possible questions (reusable across forms)
model Question {
  id            String         @id @default(cuid())
  text          String
  type          String // 'radio', 'text', 'checkbox', etc.
  alias         String         @unique // e.g. 'parent_insult', 'physical_harm'
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  formQuestions FormQuestion[]

  @@map("question")
}

// Junction: which questions belong to which form, and in what order
model FormQuestion {
  id         String   @id @default(cuid())
  formId     String
  questionId String
  order      Int // 1-based position for display and mapping
  form       Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([formId, questionId])
  @@index([formId])
  @@index([questionId])
  @@map("form_question")
}

// Assigns forms to users (tasks); completion tracked here
model FormAssignment {
  id          String    @id @default(cuid())
  userId      String
  formId      String
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  form        Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([userId, formId])
  @@index([userId])
  @@index([formId])
  @@map("form_assignment")
}

// ACE-specific response table. Responses stored as JSON mapping question alias -> value (boolean string or text)
model AceResponse {
  id          String   @id @default(cuid())
  userId      String
  responses   String // JSON: { "alias1": "true", "alias2": "false", ... }
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ace_response")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ------------------------------------------------------------------
// PDF / Word / Google-Docs converter pipeline
// ------------------------------------------------------------------

// Tracks an uploaded source document and its extraction status
model DocumentUpload {
  id              String           @id @default(cuid())
  originalName    String           // e.g. "intake-form.pdf"
  mimeType        String           // "application/pdf" | "application/vnd.openxmlformats…" | "application/vnd.google-apps.document"
  storagePath     String           // server-side path or gdoc ID
  status          String           @default("pending") // "pending" | "extracting" | "review" | "saved" | "error"
  errorMessage    String?
  sourceUrl       String?          // for Google Docs: the public/shared URL
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  extractedFields ExtractedField[]
  savedFormId     String?          // set once the admin saves it as a Form
  savedForm       Form?            @relation(fields: [savedFormId], references: [id])

  @@index([status])
  @@map("document_upload")
}

// One row per field (question) extracted from a document; admin edits these before saving
model ExtractedField {
  id           String         @id @default(cuid())
  documentId   String
  document     DocumentUpload @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fieldIndex   Int            // zero-based position in the extraction result
  label        String         // question text as extracted
  type         String         // "text" | "number" | "date" | "checkbox" | "dropdown" | "radio"
  options      String?        // JSON array of strings, only for checkbox/dropdown/radio
  // metadata from the source document
  pageNumber   Int?           // PDF: page where label was found
  boundingBox  String?        // JSON: {x0, y0, x1, y1} for PDF bounding box
  elementIndex Int?           // Word/GDocs: paragraph or structural-element index
  // extraction quality
  confidence   String         @default("high") // "high" | "low"
  isDeleted    Boolean        @default(false)  // soft-delete; admin can remove bad fields
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([documentId])
  @@map("extracted_field")
}

// Allow Form to reference a DocumentUpload (back-relation for savedForm)
// (No extra model needed — the relation is declared on DocumentUpload above)
