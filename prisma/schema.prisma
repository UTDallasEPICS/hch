generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  CLIENT
}

enum ClientStatus {
  INCOMPLETE
  WAITLIST
  ACTIVE
  ARCHIVED
}

model Client {
  id             String       @id @default(cuid())
  userId         String       @unique
  status         ClientStatus @default(INCOMPLETE)
  therapyWeek    Int?         // 0-26, max weeks of therapy
  missedSessions Int          @default(0) // count of missed therapy sessions
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions    ClientPermission?
  sessionNotes   SessionNote[]
  plan           ClientPlan?

  @@index([status])
  @@map("client")
}

// Controls what clients can see on their dashboard
model ClientPermission {
  id              String   @id @default(cuid())
  clientId        String   @unique
  canViewScores   Boolean  @default(false)
  canViewNotes    Boolean  @default(false)
  canViewPlan     Boolean  @default(false)
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_permission")
}

model SessionNote {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("session_note")
}

model ClientPlan {
  id        String   @id @default(cuid())
  clientId  String   @unique
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_plan")
}

model User {
  id              String           @id
  name            String
  email           String
  emailVerified   Boolean          @default(false)
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sessions        Session[]
  accounts        Account[]
  role            Role             @default(CLIENT)
  phoneNumber     Int?
  appForms        AppForm[]
  appQuestions    AppQuestion[]
  formAssignments FormAssignment[]
  aceResponses    AceResponse[]
  gadForms        GadForm[]
  gadQuestions    GadQuestion[]
  phqForm         PhqForm[]
  phqQuestions    PhqQuestion[]

  PclForms       PclForm[]
  PclQuestions   PclQuestion[]
  client         Client?

  @@unique([email])
  @@map("user")
}

// Form metadata (e.g. ACE Questionnaire)
model Form {
  id            String           @id @default(cuid())
  title         String
  description   String?
  slug          String           @unique // e.g. 'ace-form'
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  formQuestions FormQuestion[]
  assignments   FormAssignment[]

  @@map("form")
}

// Master list of all possible questions (reusable across forms)
model Question {
  id            String         @id @default(cuid())
  text          String
  type          String // 'radio', 'text', 'checkbox', etc.
  alias         String         @unique // e.g. 'parent_insult', 'physical_harm'
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  formQuestions FormQuestion[]

  @@map("question")
}

// Junction: which questions belong to which form, and in what order
model FormQuestion {
  id         String   @id @default(cuid())
  formId     String
  questionId String
  order      Int // 1-based position for display and mapping
  form       Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([formId, questionId])
  @@index([formId])
  @@index([questionId])
  @@map("form_question")
}

// Assigns forms to users (tasks); completion tracked here
model FormAssignment {
  id          String    @id @default(cuid())
  userId      String
  formId      String
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  form        Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([userId, formId])
  @@index([userId])
  @@index([formId])
  @@map("form_assignment")
}

// ACE-specific response table. Responses stored as JSON mapping question alias -> value (boolean string or text)
model AceResponse {
  id          String   @id @default(cuid())
  userId      String
  responses   String // JSON: { "alias1": "true", "alias2": "false", ... }
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ace_response")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AppForm {
  id          Int          @id @default(autoincrement())
  userId      String       @unique
  status      String       @default("IN_PROGRESS")
  submittedAt DateTime?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   AppQuestion?
}

