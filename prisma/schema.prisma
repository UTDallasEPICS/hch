model GadForm {
  id          Int          @id @default(autoincrement())
  userId      String
  status      String       @default("IN_PROGRESS")
  totalScore  Int?
  severity    String?
  submittedAt DateTime?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   GadQuestion?

  @@index([userId])
}

model GadQuestion {
  id     Int     @id @default(autoincrement())
  formId Int     @unique
  userId String
  g01    Int?
  g02    Int?
  g03    Int?
  g04    Int?
  g05    Int?
  g06    Int?
  g07    Int?
  g08    Int?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  form   GadForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PhqForm {
  id          Int          @id @default(autoincrement())
  userId      String       @unique
  status      String       @default("IN_PROGRESS")
  totalScore  Int?
  submittedAt DateTime?
  severity    String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   PhqQuestion?

  @@index([userId])
}

model PhqQuestion {
  id     Int     @id @default(autoincrement())
  formId Int     @unique
  userId String
  q1     Int?
  q2     Int?
  q3     Int?
  q4     Int?
  q5     Int?
  q6     Int?
  q7     Int?
  q8     Int?
  q9     Int?
  q10    Int?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  form   PhqForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PclForm {
  id          Int          @id @default(autoincrement())
  userId      String
  status      String       @default("IN_PROGRESS")
  submittedAt DateTime?
  severity    String?
  totalScore  Int?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   PclQuestion?

  @@index([userId])
}

model PclQuestion {
  id     Int     @id @default(autoincrement())
  formId Int     @unique
  userId String
  q01    Int?
  q02    Int?
  q03    Int?
  q04    Int?
  q05    Int?
  q06    Int?
  q07    Int?
  q08    Int?
  q09    Int?
  q10    Int?
  q11    Int?
  q12    Int?
  q13    Int?
  q14    Int?
  q15    Int?
  q16    Int?
  q17    Int?
  q18    Int?
  q19    Int?
  q20    Int?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  form   PclForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model change_audit {
  id                  String   @id
  entityType          String
  entityId            String
  oldValue            String?
  newValue            String?
  reasoning           String?
  documentationBase64 String?
  signatureData       String
  signedById          String
  signedAt            DateTime @default(now())
  user                User     @relation(fields: [signedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
}

enum Role {
  ADMIN
  CLIENT
}

enum ClientStatus {
  INCOMPLETE
  WAITLIST
  ACTIVE
  ARCHIVED
}
